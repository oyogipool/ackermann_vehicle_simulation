<?xml version="1.0" ?>

<sdf version="1.10" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="vehicle_name" value="sputnik"/>

  <xacro:property name="chassis_depth" value="0.01"/>
  <xacro:property name="wheelbase" value="0.324"/>
  <xacro:property name="half_width" value="0.196"/>
  <xacro:property name="half_track" value="0.148"/>
  <!--<xacro:property name="chassis_mass" value="1.68"/>-->
  <xacro:property name="chassis_mass" value="5"/>
  <xacro:property name="tire_radius" value="0.05475"/>
  <xacro:property name="chassis_height_offset" value="0.02"/>
  <xacro:property name="tire_inner_rad" value="0.056"/>
  <xacro:property name="tire_width" value="0.0445"/>
  <xacro:property name="tire_mass" value="0.15"/>
  <xacro:property name="max_steer_ang" value="0.4"/>
  <xacro:property name="laser2axle" value="0.0476"/>
  <xacro:property name="laser_rotation" value="0.0"/>
  <!--<xacro:property name="laser_rotation" value="-${pi}"/>-->
  <xacro:property name="laser_height" value="0.1"/>
  <xacro:property name="imu2axle" value="0.11"/>
  <xacro:property name="imu_x_rotation" value="${pi}"/>
  <xacro:property name="imu_update_rate" value="250"/>
  
  <xacro:property name="counterweight_mass" value="${chassis_mass + 4*tire_mass}"/>
  <xacro:property name="counterweight_com" value="${((chassis_mass*(tire_radius+chassis_height_offset)) + 4*tire_mass*tire_radius) / counterweight_mass}"/>
  
  <xacro:property name="track" value="${2*half_track}"/>
  <xacro:property name="max_turn_radius" value="${wheelbase/sin(max_steer_ang)}"/>
  <xacro:property name="inside_max_steer_ang" value="${atan(wheelbase/((wheelbase/tan(max_steer_ang))-half_track))}"/>
  <xacro:property name="steer_traverse_time" value="0.25"/>
  <xacro:property name="steer_joint_velocity_limit" value="${2*inside_max_steer_ang/steer_traverse_time}"/>
  <xacro:property name="outside_max_steer_ang" value="${atan(wheelbase/((wheelbase/tan(max_steer_ang))+half_track))}"/>
  
  <xacro:property name="tire_friction" value="1000"/>
  <xacro:property name="min_depth" value="0.02"/>
  
  <!-- Null inertial element. This is needed to make the model work with
       Gazebo. -->
  <xacro:macro name="null_inertial">
    <inertial>   
      <mass>0.001</mass>
      <inertia>
        <ixx>0.001</ixx>
        <ixy>0</ixy>
        <ixz>0</ixz>
        <iyy>0.001</iyy>
        <iyz>0</iyz>
        <izz>0.001</izz>
      </inertia>
    </inertial>
  </xacro:macro>
  
  <!-- Inertia of a solid cuboid. Width is measured along the x axis, depth
       along the y axis, and height along the z axis. -->
  <xacro:macro name="solid_cuboid_inertial" params="width depth height mass">
    <inertial>
      <mass>${mass}</mass>
      <inertia>
        <ixx>${mass * (depth * depth + height * height) / 12}</ixx>
        <ixy>0</ixy>
        <ixz>0</ixz>
        <iyy>${mass * (width * width + height * height) / 12}</iyy>
        <iyz>0</iyz>
        <izz>${mass * (width * width + depth * depth) / 12}</izz>
      </inertia>
    </inertial>    
  </xacro:macro>
  
  <!-- Inertia of a thick-walled cylindrical tube with open ends. Height is
       measured along the z axis, which is the tube's axis. inner_rad and
       outer_rad are the tube's inner and outer radii, respectively. -->
  <xacro:macro name="thick_walled_tube_inertial" params="inner_rad outer_rad height mass">
    <inertial>
      <mass>${mass}</mass>
      <inertia>
        <ixx>${(1 / 12) * mass * (3 * (inner_rad * inner_rad +
          outer_rad * outer_rad) + height * height)}</ixx>
        <ixy>0</ixy>
        <ixz>0</ixz>
        <iyy>${(1 / 12) * mass * (3 * (inner_rad * inner_rad +
          outer_rad * outer_rad) + height * height)}</iyy>
        <iyz>0</iyz>
        <izz>${mass * (inner_rad * inner_rad +
          outer_rad * outer_rad) / 2}</izz>
      </inertia>
    </inertial>    
  </xacro:macro>
  
  <xacro:macro name="wheel_friction" params="tire_friction min_depth">
    <surface>
      <friction>
        <ode>
          <mu>${tire_friction}</mu>
          <mu2>${tire_friction}</mu2>
          <fdir1>1 0 0</fdir1>
          <slip1>0</slip1>
          <slip2>0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <min_depth>${min_depth}</min_depth>
        </ode>
      </contact>
    </surface>
  </xacro:macro>
  

  <model name="slash_4x4_ultimate">
  
    <static>false</static>
    
    <link name="base">
      <gravity>true</gravity>
      <xacro:solid_cuboid_inertial
        width="${wheelbase}" depth="${2*(half_track - tire_width - 0.01)}" height="${chassis_depth}" mass="${chassis_mass}"/>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>${wheelbase} ${2*(half_track - tire_width - 0.01)} ${chassis_depth}</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <material>
          <diffuse>0 0 1 1</diffuse>
        </material>
        <geometry>
          <box>
            <size>${wheelbase} ${2*(half_track - tire_width - 0.01)} ${chassis_depth}</size>
          </box>
        </geometry>
      </visual>
    </link>
    
    <joint name="counterweight_joint" type="fixed">
      <pose relative_to="base">0 0 -${(2*tire_radius) + chassis_height_offset + counterweight_com} 0 0 0</pose>
      <parent>base</parent>
      <child>counterweight</child>
    </joint>
    <link name="counterweight">
      <!--<pose>0 0 -${tire_radius + chassis_height_offset + counterweight_com} 0 0 0</pose>-->
      <pose relative_to="counterweight_joint">0 0 0 0 0 0</pose>
      <gravity>true</gravity>
      <xacro:solid_cuboid_inertial
        width="${wheelbase}" depth="${2*(half_track - tire_radius - 0.01)}" height="${chassis_depth}" mass="${counterweight_mass}"/>
      <visual name="counterweight_visual">
        <material>
          <diffuse>0 0 0 1</diffuse>
        </material>
        <geometry>
          <box>
            <size>0.03 0.03 0.001</size>
          </box>
        </geometry>
      </visual>      
    </link>
    
    <joint name="front_axle_center_joint" type="fixed">
      <pose relative_to="base">${wheelbase/2} 0 0 0 0 0</pose>
      <parent>base</parent>
      <child>front_axle_center</child>
    </joint>
    <link name="front_axle_center">
      <pose relative_to="front_axle_center_joint">0 0 0 0 0 0</pose> 
    </link>
    
    <joint name="imu_joint" type="fixed">
      <pose relative_to="front_axle_center">${-imu2axle} 0 0 ${imu_x_rotation} 0 0</pose>
      <parent>front_axle_center</parent>
      <child>imu_link</child>
    </joint>
    <link name="imu_link">
      <pose relative_to="imu_joint">0 0 0 0 0 0</pose>
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>${imu_update_rate}</update_rate>
        <visualize>true</visualize>
        <topic>imu</topic>
      </sensor>
    </link>

    <joint name="left_steer_joint" type="revolute" >
      <parent>base</parent>
      <child>left_steer_link</child>
      <pose relative_to="base">${wheelbase/2} ${half_track} -${chassis_height_offset} 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>${-outside_max_steer_ang}</lower>
          <upper>${inside_max_steer_ang}</upper>
          <velocity>${steer_joint_velocity_limit}</velocity>
          <effort>1e6</effort>
        </limit>
      </axis>
    </joint>
    <link name="left_steer_link">
      <pose relative_to="left_steer_joint">0 0 0 0 0 0</pose>
    </link>
    
    <joint name="right_steer_joint" type="revolute" >
      <parent>base</parent>
      <child>right_steer_link</child>
      <pose relative_to="base">${wheelbase/2} -${half_track} -${chassis_height_offset} 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>${-inside_max_steer_ang}</lower>
          <upper>${outside_max_steer_ang}</upper>
          <velocity>${steer_joint_velocity_limit}</velocity>
          <effort>1e6</effort>
        </limit>
      </axis>
    </joint>
    <link name="right_steer_link">
      <pose relative_to="right_steer_joint">0 0 0 0 0 0</pose>
    </link>

    <joint name="front_left_wheel_joint" type="revolute">
      <parent>left_steer_link</parent>
      <child>front_left_wheel</child>
      <pose relative_to="left_steer_joint">0 0 0 ${pi/2} 0 0</pose>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>
    <link name="front_left_wheel">
      <pose relative_to="front_left_wheel_joint">0 0 0 0 0 0</pose>
      <gravity>true</gravity>
      <xacro:thick_walled_tube_inertial
        inner_rad="${tire_inner_rad}" outer_rad="${tire_radius}"
        height="${tire_width}" mass="${tire_mass}"/>
      <collision name="front_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry><robot_base_frame>sputnik/rplidar_a3/lidar_link/gpu_lidar</robot_base_frame>
        <xacro:wheel_friction tire_friction="${tire_friction}" min_depth="${min_depth}"/>
      </collision>
      <visual name="front_left_wheel_visual">
        <material>
          <diffuse>0 0 0 1</diffuse>
        </material>
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
        
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>right_steer_link</parent>
      <child>front_right_wheel</child>
      <pose relative_to="right_steer_joint">0 0 0 ${pi/2} 0 0</pose>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>
    <link name="front_right_wheel">
      <pose relative_to="front_right_wheel_joint">0 0 0 0 0 0</pose>
      <gravity>true</gravity>
      <xacro:thick_walled_tube_inertial
        inner_rad="${tire_inner_rad}" outer_rad="${tire_radius}"
        height="${tire_width}" mass="${tire_mass}"/>
      <collision name="front_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
        <xacro:wheel_friction tire_friction="${tire_friction}" min_depth="${min_depth}"/>
      </collision>
      <visual name="front_right_wheel_visual">
        <material>
          <diffuse>0 0 0 1</diffuse>
        </material>
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    
    <joint name="rear_left_wheel_joint" type="revolute">      
      <parent>base</parent>
      <child>rear_left_wheel</child>
      <pose relative_to="base">${-wheelbase/2} ${half_track} -${chassis_height_offset} ${pi/2} 0 0</pose>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>
    <link name="rear_left_wheel">
      <pose relative_to="rear_left_wheel_joint">0 0 0 0 0 0</pose>
      <gravity>true</gravity>
      <xacro:thick_walled_tube_inertial
        inner_rad="${tire_inner_rad}" outer_rad="${tire_radius}"
        height="${tire_width}" mass="${tire_mass}"/>
      <collision name="rear_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
        <xacro:wheel_friction tire_friction="${tire_friction}" min_depth="${min_depth}"/>
      </collision>
      <visual name="rear_left_wheel_visual">
        <material>
          <diffuse>0 0 0 1</diffuse>
        </material>
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name="rear_right_wheel_joint" type="revolute">      
      <parent>base</parent>
      <child>rear_right_wheel</child>
      <pose relative_to="base">${-wheelbase/2} ${-half_track} -${chassis_height_offset} ${pi/2} 0 0</pose>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>
    <link name="rear_right_wheel">
      <pose relative_to="rear_right_wheel_joint">0 0 0 0 0 0</pose>
      <gravity>true</gravity>
      <xacro:thick_walled_tube_inertial
        inner_rad="${tire_inner_rad}" outer_rad="${tire_radius}"
        height="${tire_width}" mass="${tire_mass}"/>
      <collision name="rear_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
        <xacro:wheel_friction tire_friction="${tire_friction}" min_depth="${min_depth}"/>
      </collision>
      <visual name="rear_right_wheel_visual">
        <material>
          <diffuse>0 0 0 1</diffuse>
        </material>
        <geometry>
          <cylinder>
            <radius>${tire_radius}</radius>
            <length>${tire_width}</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    
    <!-- Laser -->
    <joint name="base_to_laser_rviz" type="fixed">
      <parent>base</parent>
      <child>sputnik/rplidar_a3/lidar_link/gpu_lidar</child>    
      <pose relative_to="base">${wheelbase/2 - laser2axle} 0 ${laser_height} 0 0 ${laser_rotation}</pose>
    </joint>
    <link name="sputnik/rplidar_a3/lidar_link/gpu_lidar">
      <pose relative_to="base_to_laser_rviz">0 0 0 0 0 0</pose> 
    </link>
    <joint name="base_to_laser_sensor" type="fixed">
      <parent>base</parent>
      <child>rplidar_a3::lidar_link</child>    
      <pose relative_to="base">${wheelbase/2 - laser2axle} 0 ${laser_height} 0 0 ${laser_rotation}</pose>
    </joint>
    <include>
      <uri>model://rplidar_a3</uri>
      <pose relative_to="base_to_laser_sensor">0 0 0 0 0 0</pose>
    </include>
        
    <!-- Plugins> -->
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>left_steer_joint</joint_name>
      <cmd_max>${steer_joint_velocity_limit}</cmd_max>
      <use_velocity_commands>true</use_velocity_commands>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>right_steer_joint</joint_name>
      <cmd_max>${steer_joint_velocity_limit}</cmd_max>
      <use_velocity_commands>true</use_velocity_commands>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>front_left_wheel_joint</joint_name>
      <use_force_commands>false</use_force_commands>
      <topic>/model/sputnik/joint/front_left_wheel_joint/cmd_vel</topic>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>front_right_wheel_joint</joint_name>
      <use_force_commands>false</use_force_commands>
      <topic>/model/sputnik/joint/front_right_wheel_joint/cmd_vel</topic>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>rear_left_wheel_joint</joint_name>
      <use_force_commands>false</use_force_commands>
      <topic>/model/sputnik/joint/rear_left_wheel_joint/cmd_vel</topic>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>rear_right_wheel_joint</joint_name>
      <use_force_commands>false</use_force_commands>
      <topic>/model/sputnik/joint/rear_right_wheel_joint/cmd_vel</topic>
    </plugin>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>/model/${vehicle_name}/joint_state</topic>
      <joint_name>left_steer_joint</joint_name>
      <joint_name>right_steer_joint</joint_name>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
    <!--<plugin
      filename="gz-sim-pose-publisher-system"
      name="gz::sim::systems::PosePublisher">
      <publish_model_pose>true</publish_model_pose>
      <static_publisher>true</static_publisher>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_update_frequency>-1</static_update_frequency>
    </plugin>-->
    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_frame>world/ground_plane</odom_frame>
      <!--<robot_base_frame>sputnik/rplidar_a3/lidar_link/gpu_lidar</robot_base_frame>-->
      <robot_base_frame>sputnik/base</robot_base_frame>
      <odom_publish_frequency>500</odom_publish_frequency>
    </plugin>
  </model>
</sdf>

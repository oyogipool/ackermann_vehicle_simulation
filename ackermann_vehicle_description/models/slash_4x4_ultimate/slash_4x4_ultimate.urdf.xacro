<?xml version="1.0"?>
<robot name="sputnik"
       xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= PROPERTIES ================= -->

  <xacro:property name="vehicle_name" value="sputnik"/>

  <xacro:property name="chassis_depth" value="0.01"/>
  <xacro:property name="wheelbase" value="0.324"/>
  <xacro:property name="half_width" value="0.196"/>
  <xacro:property name="half_track" value="0.148"/>
  <xacro:property name="chassis_mass" value="5"/>
  <xacro:property name="tire_radius" value="0.05475"/>
  <xacro:property name="chassis_height_offset" value="0.02"/>
  <xacro:property name="tire_inner_rad" value="0.056"/>
  <xacro:property name="tire_width" value="0.0445"/>
  <xacro:property name="tire_mass" value="0.15"/>

  <!-- ================= BASE LINK ================= -->

  <link name="base_link">

    <visual>
      <origin xyz="0 0 ${tire_radius + chassis_height_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${wheelbase} ${2*half_width} ${chassis_depth}"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 ${tire_radius + chassis_height_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${wheelbase} ${2*half_width} ${chassis_depth}"/>
      </geometry>
    </collision>

  </link>

  <!-- ================= WHEEL MACRO ================= -->

  <xacro:macro name="wheel" params="name x y">

    <link name="${name}_wheel_link">

      <visual>
        <origin xyz="0 0 0" rpy="1.570796 0 0"/>
        <geometry>
          <cylinder radius="${tire_radius}" length="${tire_width}"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.570796 0 0"/>
        <geometry>
          <cylinder radius="${tire_radius}" length="${tire_width}"/>
        </geometry>
      </collision>

    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x} ${y} ${tire_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- ================= WHEELS ================= -->

  <xacro:wheel
    name="front_left"
    x="${wheelbase/2}"
    y="${half_track}"/>

  <xacro:wheel
    name="front_right"
    x="${wheelbase/2}"
    y="-${half_track}"/>

  <xacro:wheel
    name="rear_left"
    x="-${wheelbase/2}"
    y="${half_track}"/>

  <xacro:wheel
    name="rear_right"
    x="-${wheelbase/2}"
    y="-${half_track}"/>

  <!-- ================= LASER ================= -->

  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.0476 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ================= IMU ================= -->

  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.11 0 0" rpy="3.14159 0 0"/>
  </joint>

</robot>
